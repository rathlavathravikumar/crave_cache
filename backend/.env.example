# CraveCache Backend Configuration

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/cravecache?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Server
PORT=5000
NODE_ENV=development

# Cloudinary
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Stripe
STRIPE_API_KEY=sk_test_your_stripe_key
STRIPE_API_SECRET=sk_test_your_stripe_secret

# Email Configuration
SMTP_SERVICE=gmail
SMTP_MAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@cravecache.com
SMTP_FROM_NAME=CraveCache

# Groq API (for AI features)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3-8b-chat

# OpenAI API (alternative to Groq)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-3.5-turbo

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Deployment
VERCEL_URL=
RENDER_URL=

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Tax Configuration
DEFAULT_TAX_RATE=0.05
GST_RATE=0.18

# Delivery Configuration
DEFAULT_DELIVERY_CHARGE=50
DEFAULT_DELIVERY_TIME=30
DELIVERY_RADIUS_KM=5

# Admin
ADMIN_EMAIL=admin@cravecache.com
ADMIN_PASSWORD=secure_password_change_this
